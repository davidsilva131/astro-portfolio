---
import Badge from "../atoms/Badge.astro";

interface Props {
  period: string;
  title: string;
  description: string;
  stack: string[];
}

const { period, title, description, stack } = Astro.props;
---

<div class="relative pl-6 border-l border-zinc-200 dark:border-zinc-800">
  <span class="text-xs font-mono text-zinc-500 dark:text-zinc-400">{period}</span>
  <h3 class="mt-1 text-lg font-semibold text-zinc-900 dark:text-zinc-100">{title}</h3>
  <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{description}</p>
  <div class="mt-3 flex flex-wrap gap-1.5">
    {stack.map((tech) => <Badge label={tech} />)}
  </div>
</div>

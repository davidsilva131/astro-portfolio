---
import Badge from "../atoms/Badge.astro";

interface Props {
  title: string;
  description: string;
  stack: string[];
  status?: "completed" | "in-progress";
  href?: string;
}

const { title, description, stack, status = "completed", href } = Astro.props;
---

<article
  class="group p-5 rounded-lg border border-zinc-200 dark:border-zinc-800 hover:border-cyan-500/40 dark:hover:border-cyan-500/30 transition-colors duration-200"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-2">
      <h3
        class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors duration-150"
      >
        {title}
      </h3>
      {href && (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} live`}
          class="text-zinc-400 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors duration-150"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Zm6.75-3a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0V3.56l-3.97 3.97a.75.75 0 0 1-1.06-1.06l3.97-3.97H11a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
        </a>
      )}
    </div>
    {
      status === "in-progress" && (
        <span class="shrink-0 text-xs font-medium text-amber-600 dark:text-amber-400">
          In progress
        </span>
      )
    }
  </div>
  <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{description}</p>
  <div class="mt-4 flex flex-wrap gap-1.5">
    {stack.map((tech) => <Badge label={tech} />)}
  </div>
</article>

<section
  id="contact"
  aria-label="Get in Touch"
  class="max-w-3xl mx-auto px-6 py-20 border-t border-zinc-200/60 dark:border-zinc-800/60"
>
  <span class="text-xs font-semibold tracking-widest uppercase text-cyan-600 dark:text-cyan-400">
    Contact
  </span>
  <h2 class="mt-2 text-3xl font-bold text-zinc-900 dark:text-zinc-100">Get in Touch</h2>
  <p class="mt-4 max-w-md text-zinc-600 dark:text-zinc-400 leading-relaxed">
    Open to new opportunities. If you have a project in mind or just want to
    connect — my inbox is always open.
  </p>

  <div class="mt-8 flex flex-col gap-4">
    {/* TODO: replace with your real email address */}
    <a
      href="mailto:your@email.com"
      class="text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-cyan-600 dark:hover:text-cyan-400 transition-colors duration-150 w-fit"
    >
      your@email.com
    </a>
    <div class="flex items-center gap-4">
      {/* TODO: replace with your real GitHub profile URL */}
      <a
        href="#"
        aria-disabled="true"
        class="text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors duration-150"
      >
        GitHub
      </a>
      <span class="text-zinc-300 dark:text-zinc-700">·</span>
      {/* TODO: replace with your real LinkedIn profile URL */}
      <a
        href="#"
        aria-disabled="true"
        class="text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors duration-150"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>

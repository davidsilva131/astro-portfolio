---
import Badge from "../atoms/Badge.astro";

const stack = [
  { category: "Frontend", items: ["React 18", "Next.js", "TypeScript", "JavaScript", "HTML5", "CSS", "Sass", "Tailwind CSS", "Material UI", "Shadcn"] },
  { category: "State", items: ["Redux", "RTK", "Zustand"] },
  { category: "Backend & DB", items: ["Node.js", "SQL", "SQLite", "PostgreSQL", "Firebase", "Firestore", "Supabase", "Axios"] },
  { category: "Tools", items: ["Git", "GitHub", "Azure", "Three.js"] },
];
---

<section id="about" aria-label="About Juan David Silva Contreras" class="max-w-3xl mx-auto px-6 pt-24 pb-20">
  <span class="text-sm font-semibold tracking-widest uppercase text-cyan-600 dark:text-cyan-400">
    Frontend Developer
  </span>
  <h1 class="mt-4 text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 leading-tight">
    Juan David<br />Silva Contreras
  </h1>
  <p class="mt-6 max-w-xl text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">
    I build fast, accessible and visually refined web interfaces. Focused on
    crafting clean, maintainable code with modern tools.
  </p>
  <div class="mt-8 flex flex-col gap-3">
    {stack.map(({ category, items }) => (
      <div class="flex items-start gap-4">
        <span class="w-24 shrink-0 pt-0.5 text-xs font-mono text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">
          {category}
        </span>
        <div class="flex flex-wrap gap-1.5">
          {items.map((tech) => <Badge label={tech} />)}
        </div>
      </div>
    ))}
  </div>
</section>

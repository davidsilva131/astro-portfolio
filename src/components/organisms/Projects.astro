---
import SectionHeader from "../molecules/SectionHeader.astro";
import ProjectCard from "../molecules/ProjectCard.astro";

const projects = [
  {
    title: "LotoPetsPlay",
    description:
      "Gaming platform themed around pets, featuring user accounts, match history, and real-time data management.",
    stack: ["Next.js", "Tailwind CSS", "Supabase"],
    status: "in-progress" as const,
  },
  {
    title: "VFX Ayverson",
    description:
      "Professional portfolio for a video designer and editor, showcasing a work gallery and personal brand presentation.",
    stack: ["Astro", "Tailwind CSS"],
    status: "completed" as const,
    href: "https://vfx-ayverson.davidsilvac131.workers.dev/",
  },
];
---

<section
  id="projects"
  aria-label="Things I've Built"
  class="max-w-3xl mx-auto px-6 py-20 border-t border-zinc-200/60 dark:border-zinc-800/60"
>
  <SectionHeader label="Projects" title="Things I've Built" />
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>

---
import ThemeToggle from "../molecules/ThemeToggle.astro";

const links = [
  { href: "#about", label: "about" },
  { href: "#experience", label: "experience" },
  { href: "#projects", label: "projects" },
  { href: "#resume", label: "resume" },
  { href: "#contact", label: "contact" },
];
---

<header
  class="sticky top-0 z-50 bg-white/80 dark:bg-black/80 backdrop-blur-md border-b border-zinc-200/60 dark:border-zinc-800/60"
>
  <nav
    aria-label="Main navigation"
    class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between"
  >
    <a
      href="#about"
      class="text-sm font-bold text-zinc-900 dark:text-zinc-100 hover:text-cyan-600 dark:hover:text-cyan-400 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 rounded-sm"
    >
      jdsc.
    </a>

    <div class="flex items-center gap-3">
      <!-- Desktop links -->
      <ul class="hidden sm:flex items-center gap-5 list-none" role="list">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 rounded-sm"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <ThemeToggle />

      <!-- Mobile hamburger toggle (hidden on sm+) -->
      <button
        id="mobile-menu-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="sm:hidden rounded-md p-1.5 text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-500"
      >
        <!-- Hamburger icon -->
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <!-- Close icon -->
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="hidden"
        >
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    hidden
    class="sm:hidden border-t border-zinc-200/60 dark:border-zinc-800/60 bg-white/95 dark:bg-black/95 backdrop-blur-md"
  >
    <ul class="max-w-3xl mx-auto px-6 py-4 flex flex-col gap-1 list-none" role="list">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="block py-2 text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500 rounded-sm"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle") as HTMLButtonElement | null;
  const menu = document.getElementById("mobile-menu") as HTMLElement | null;
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const isOpen = !menu.hidden;
    menu.hidden = isOpen;
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Open navigation menu" : "Close navigation menu");
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
  });

  // Close menu when any link inside it is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (!menu || !toggle) return;
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Open navigation menu");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>

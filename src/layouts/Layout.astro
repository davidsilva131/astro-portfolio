---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Juan David Silva Contreras — Frontend Developer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Juan David Silva Contreras — Frontend Developer portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const t =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.classList.toggle("dark", t === "dark");
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-white text-zinc-900 antialiased transition-[background-color,color] duration-300
           dark:bg-gradient-to-br dark:from-black dark:via-zinc-950 dark:to-slate-900 dark:text-zinc-100"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:text-zinc-900 focus:rounded focus:outline focus:outline-2 focus:outline-cyan-500"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
